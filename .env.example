NODE_ENV=development
PORT=3000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@HOST:5432/postgres
DATABASE_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@HOST:5432/postgres
SUPABASE_STORAGE_BUCKET=reports

COOKIE_NAME=app_session_id
ADMIN_COOKIE_NAME=admin_session_token
ADMIN_JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_RANDOM_SECRET
ADMIN_JWT_TTL_MINUTES=60
ADMIN_JWT_ISSUER=portal-vetneb-api
ADMIN_JWT_AUDIENCE=portal-vetneb-admin

CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY=1

OWNER_OPEN_ID=
LAB_UPLOAD_USERNAMES=

MAX_UPLOAD_FILE_SIZE_MB=20
SUPABASE_SIGNED_URL_EXPIRES_IN_SECONDS=900
SESSION_TTL_HOURS=24
