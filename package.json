{
  "name": "portal-vetneb-backend",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p ./test/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "smoke:test": "node scripts/smoke/smoke-test.mjs",
    "smoke:upload": "node scripts/smoke/smoke-upload.mjs",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --test test/**/*.test.ts",
    "validate:local": "pnpm typecheck && pnpm typecheck:test && pnpm test && pnpm build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "argon2": "^0.44.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.31.4",
    "fastify": "^5.8.5",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.22.8",
    "esbuild": "^0.21.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
